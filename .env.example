# ---------------------------------------------------------
# Laffeh - Environment variables
# Copy this file to `.env` (gitignored) and fill in real values.
# Never commit real API keys to source control.
# ---------------------------------------------------------

# Afdal VRP AI API
AI_ROUTE_BASE_URL=https://back.laffa.afdal.tech/api/v1
AI_ROUTE_API_KEY=YOUR_AI_ROUTE_API_KEY_HERE

# Map/geocoding providers
OSM_TILE_URL_TEMPLATE=https://basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}@2x.png
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE
