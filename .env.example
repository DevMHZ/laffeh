# ---------------------------------------------------------
# Laffeh - Environment variables
# Copy this file to `.env` (gitignored) and fill in real values.
# Never commit real API keys to source control.
# ---------------------------------------------------------

# Google Maps SDK key (used by Android + iOS native sides and Directions API).
# Get one from https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Afdal VRP AI API
AI_ROUTE_BASE_URL=https://back.laffa.afdal.tech/api/v1
AI_ROUTE_API_KEY=test-key-001
